{
    "version": 8,
    "configurePresets": [
        {
            "name": "GCC 14.2.0 x86_64-w64-mingw32 (ucrt64)",
            "displayName": "GCC 14.2.0 x86_64-w64-mingw32 (ucrt64)",
            "description": "Using compilers from external/mingw64",
            "generator": "MinGW Makefiles",
            "binaryDir": "${sourceDir}/out/build/simplefactory",
            "cacheVariables": {
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}",
                "CMAKE_C_COMPILER": "${sourceDir}/external/mingw64/bin/gcc.exe",
                "CMAKE_CXX_COMPILER": "${sourceDir}/external/mingw64/bin/g++.exe",
                "CMAKE_MAKE_PROGRAM": "${sourceDir}/external/mingw64/bin/mingw32-make.exe",
                "SFML_DIR": "${sourceDir}/external/SFML/lib/cmake/SFML"
            }
        },
        {
            "name": "Custom configure preset",
            "displayName": "Custom configure preset",
            "description": "Sets Ninja generator, build and install directory",
            "generator": "Ninja",
            "binaryDir": "${sourceDir}/out/build/${presetName}",
            "cacheVariables": {
                "CMAKE_BUILD_TYPE": "Debug",
                "CMAKE_INSTALL_PREFIX": "${sourceDir}/out/install/${presetName}"
            }
        }
    ]
}